      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"mern-backend-.*\"}[1m])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Backend CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
